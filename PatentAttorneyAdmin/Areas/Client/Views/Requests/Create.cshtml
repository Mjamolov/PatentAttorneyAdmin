@model PatentAttorneyAdmin.ViewModels.CreateRequestViewModel
@{
    ViewData["Title"] = L["CreateRequest"];
}

<div class="card-panel">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label>@L["SelectService"]</label>
            <select asp-for="ServiceCategoryId" asp-items="ViewBag.Services" class="form-control">
                <option value="">—</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="Type">@L["RequestType"]</label>
            <select asp-for="Type" class="form-control">
                <option value="@((int)PatentAttorneyAdmin.Models.RequestType.General)">@L["TypeGeneral"]</option>
                <option value="@((int)PatentAttorneyAdmin.Models.RequestType.Invitation)">@L["TypeInvitation"]</option>
                <option value="@((int)PatentAttorneyAdmin.Models.RequestType.DocumentCorrection)">@L["TypeDocumentCorrection"]</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="Subject"></label>
            <input asp-for="Subject" class="form-control" />
            <span asp-validation-for="Subject" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Body">@L["Message"]</label>
            <textarea asp-for="Body" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Body" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Attachment"></label>
            <input asp-for="Attachment" class="form-control" type="file" accept="@UploadFileTypes.AcceptAttribute" />
        </div>

        <button type="submit" class="btn btn-primary">@L["Send"]</button>
    </form>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
