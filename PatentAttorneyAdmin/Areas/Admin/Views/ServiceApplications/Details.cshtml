@model PatentAttorneyAdmin.Models.ServiceApplication
@using PatentAttorneyAdmin.Infrastructure
@using PatentAttorneyAdmin.Models
@{
    var isTj = (bool)ViewBag.IsTj;
    ViewData["Title"] = $"{L["ServiceApplications"]} #{Model.Id}";
    var serviceCode = Model.ServiceCategory.ServiceCode;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-3">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-success mb-3">@TempData["Info"]</div>
}

<div class="card-panel mb-3">
    <div class="action-bar">
        <h2 class="mb-0">@(isTj ? Model.ServiceCategory.TitleTj : Model.ServiceCategory.TitleRu)</h2>
        <span class="badge app-status-@Model.Status.ToString().ToLower()">@LocalizationHelper.ApplicationStatus(L, Model.Status)</span>
    </div>
</div>

<div class="card-panel mb-3">
    <h3>@L["ApplicantInfo"]</h3>
    <dl class="detail-list">
        <dt>@L["LastName"]</dt>
        <dd>@Model.User.LastName @Model.User.FirstName @Model.User.MiddleName</dd>
        <dt>@L["Email"]</dt><dd>@Model.User.Email</dd>
        <dt>@L["Phone"]</dt><dd>@Model.User.PhoneNumber</dd>
        <dt>@L["PassportSeries"]</dt>
        <dd>@Model.User.PassportSeries @Model.User.PassportNumber</dd>
        <dt>@L["Inn"]</dt><dd>@Model.User.Inn</dd>
        <dt>@L["PassportIssuedBy"]</dt><dd>@(Model.User.PassportIssuedBy ?? "—")</dd>
        <dt>@L["PassportIssuedDate"]</dt><dd>@(Model.User.PassportIssuedDate?.ToString("dd.MM.yyyy") ?? "—")</dd>
        <dt>@L["PassportExpiryDate"]</dt><dd>@(Model.User.PassportExpiryDate?.ToString("dd.MM.yyyy") ?? "—")</dd>
        <dt>@L["PassportAddress"]</dt><dd>@Model.User.PassportAddress</dd>
        <dt>@L["ActualAddress"]</dt><dd>@Model.User.ActualAddress</dd>
        <dt>@L["RegisteredAt"]</dt>
        <dd>@Model.SubmittedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
    </dl>
    @if (!string.IsNullOrEmpty(Model.User.PassportFrontPath))
    {
        <div class="action-bar">
            <a class="btn btn-sm btn-outline-primary" href="/@Model.User.PassportFrontPath" target="_blank">@L["PassportFront"]</a>
            @if (!string.IsNullOrEmpty(Model.User.PassportBackPath))
            {
                <a class="btn btn-sm btn-outline-primary" href="/@Model.User.PassportBackPath" target="_blank">@L["PassportBack"]</a>
            }
        </div>
    }
</div>

<div class="card-panel mb-3">
    <h3>@L["RequiredDocuments"] (@Model.Documents.Count)</h3>
    <div class="doc-preview-grid">
        @foreach (var doc in Model.Documents.OrderBy(d => d.DocumentType))
        {
            var labelKey = ServiceDocumentCatalog.GetLabelKey(serviceCode, doc.DocumentType);
            var isImage = doc.OriginalFileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
                || doc.OriginalFileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                || doc.OriginalFileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase);
            <div class="doc-preview-card @(doc.NeedsCorrection ? "doc-needs-correction" : "")">
                @if (isImage)
                {
                    <a href="/@doc.FilePath" target="_blank"><img src="/@doc.FilePath" alt="" class="doc-thumb" /></a>
                }
                else
                {
                    <i class="bi bi-file-earmark-pdf doc-icon-lg"></i>
                }
                <div class="doc-preview-info">
                    <strong>@L[labelKey]</strong>
                    @if (doc.NeedsCorrection)
                    {
                        <span class="badge app-status-needscorrection">@L["NeedsCorrectionBadge"]</span>
                    }
                    <span class="text-muted">@doc.OriginalFileName</span>
                    @if (!string.IsNullOrWhiteSpace(doc.StaffComment))
                    {
                        <p class="doc-staff-note">@doc.StaffComment</p>
                    }
                    <a href="/@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary mt-2">@L["View"]</a>
                </div>
            </div>
        }
    </div>
</div>

<div class="card-panel mb-3">
    <h3>@L["QuickActions"]</h3>
    <div class="action-bar">
        <form asp-action="QuickReview" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="@((int)ServiceApplicationStatus.Approved)" />
            <button type="submit" class="btn btn-success">@L["ApproveApplication"]</button>
        </form>
        <form asp-action="QuickReview" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="@((int)ServiceApplicationStatus.Rejected)" />
            <button type="submit" class="btn btn-outline-danger">@L["RejectApplication"]</button>
        </form>
    </div>
</div>

<div class="card-panel mb-3" id="correction-form">
    <h3>@L["RequestCorrection"]</h3>
    <p class="text-muted">@L["RequestCorrectionHint"]</p>
    <form asp-action="RequestCorrection" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="form-group">
            <label>@L["StaffResponse"]</label>
            <textarea name="StaffComment" class="form-control" rows="3" placeholder="@L["StaffCommentPlaceholder"]" required>@Model.StaffComment</textarea>
        </div>
        <div class="correction-docs-list">
            @foreach (var doc in Model.Documents.OrderBy(d => d.DocumentType))
            {
                var labelKey = ServiceDocumentCatalog.GetLabelKey(serviceCode, doc.DocumentType);
                var typeKey = (int)doc.DocumentType;
                <div class="correction-doc-item">
                    <label class="form-check correction-doc-check">
                        <input type="checkbox" name="DocumentsToCorrect" value="@typeKey" @(doc.NeedsCorrection ? "checked" : "") />
                        <span>@L[labelKey]</span>
                    </label>
                    <input type="text" name="DocumentComments[@typeKey]" class="form-control form-control-sm" placeholder="@L["DocumentCommentPlaceholder"]" value="@doc.StaffComment" />
                </div>
            }
        </div>
        <button type="submit" class="btn btn-warning mt-3">@L["SendCorrectionRequest"]</button>
    </form>
</div>

<div class="card-panel">
    <h3>@L["ReviewApplication"]</h3>
    <form asp-action="Review" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="form-group">
            <label>@L["Status"]</label>
            <select name="Status" class="form-control">
                @foreach (ServiceApplicationStatus s in Enum.GetValues(typeof(ServiceApplicationStatus)))
                {
                    if (s == ServiceApplicationStatus.NeedsCorrection)
                        continue;

                    if (Model.Status == s)
                    {
                        <option value="@((int)s)" selected="selected">@LocalizationHelper.ApplicationStatus(L, s)</option>
                    }
                    else
                    {
                        <option value="@((int)s)">@LocalizationHelper.ApplicationStatus(L, s)</option>
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label>@L["StaffResponse"]</label>
            <textarea name="StaffComment" class="form-control" rows="4" placeholder="@L["StaffCommentPlaceholder"]">@Model.StaffComment</textarea>
        </div>
        <button type="submit" class="btn btn-primary">@L["Save"]</button>
        <a class="btn btn-outline-secondary" asp-action="Index">@L["Back"]</a>
    </form>
</div>

