@model PatentAttorneyAdmin.Models.ApplicationUser
@using PatentAttorneyAdmin.Infrastructure
@using PatentAttorneyAdmin.Models
@{
    ViewData["Title"] = $"{L["Profile"]}: {Model.LastName} {Model.FirstName}";
}

<div class="card-panel">
    <dl class="detail-list">
        <dt>@L["LastName"]</dt><dd>@Model.LastName @Model.FirstName @Model.MiddleName</dd>
        <dt>@L["Email"]</dt><dd>@Model.Email</dd>
        <dt>@L["Phone"]</dt><dd>@Model.PhoneNumber</dd>
        <dt>@L["PassportSeries"]</dt><dd>@Model.PassportSeries @Model.PassportNumber</dd>
        <dt>@L["Inn"]</dt><dd>@Model.Inn</dd>
        <dt>@L["PassportIssuedBy"]</dt><dd>@(Model.PassportIssuedBy ?? "—")</dd>
        <dt>@L["PassportIssuedDate"]</dt><dd>@(Model.PassportIssuedDate?.ToString("dd.MM.yyyy") ?? "—")</dd>
        <dt>@L["PassportExpiryDate"]</dt><dd>@(Model.PassportExpiryDate?.ToString("dd.MM.yyyy") ?? "—")</dd>
        <dt>@L["PassportAddress"]</dt><dd>@Model.PassportAddress</dd>
        <dt>@L["ActualAddress"]</dt><dd>@Model.ActualAddress</dd>
        <dt>@L["Status"]</dt>
        <dd>
            <span class="badge status-@Model.Status.ToString().ToLower()">
                @LocalizationHelper.UserStatusLabel(L, Model.Status)
            </span>
        </dd>
        <dt>@L["PassportFront"]</dt>
        <dd>@(Model.PassportFrontPath != null ? Html.Raw($"<a href='/{Model.PassportFrontPath}' target='_blank'>{L["View"]}</a>") : "—")</dd>
        <dt>@L["PassportBack"]</dt>
        <dd>@(Model.PassportBackPath != null ? Html.Raw($"<a href='/{Model.PassportBackPath}' target='_blank'>{L["View"]}</a>") : "—")</dd>
    </dl>

    <div class="action-bar">
        @if (Model.Status != PatentAttorneyAdmin.Models.UserStatus.Active)
        {
            <form asp-action="SetStatus" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@((int)PatentAttorneyAdmin.Models.UserStatus.Active)" />
                <button type="submit" class="btn btn-primary">@L["Activate"]</button>
            </form>
        }
        @if (Model.Status != PatentAttorneyAdmin.Models.UserStatus.Disabled)
        {
            <form asp-action="SetStatus" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@((int)PatentAttorneyAdmin.Models.UserStatus.Disabled)" />
                <button type="submit" class="btn btn-outline-danger">@L["Disable"]</button>
            </form>
        }
        <a class="btn btn-outline-secondary" asp-action="Index">@L["Back"]</a>
    </div>
</div>
